        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4201
          },
          "configurations": {
            "production": {
              "buildTarget": "prescription:build:production"
            },
            "development": {
              "buildTarget": "prescription:build:development"
            }
          },
          "defaultConfiguration": "development"
